# TLC auto-generated artifacts (re-created on every run)
#  - states/                  : TLC's on-disk fingerprint set + checkpoint queue
#  - <Module>_TTrace_*.bin    : TLC trace-exploration binary (per-module)
#  - <Module>_TTrace_*.tla    : TLC trace-exploration spec (per-module)
#  - *.log                    : ad-hoc TLC log files (anything not in results/)
states/
Replication_TTrace_*.bin
Replication_TTrace_*.tla
MVCCStorage_TTrace_*.bin
MVCCStorage_TTrace_*.tla
MVCCTx_TTrace_*.bin
MVCCTx_TTrace_*.tla
*.log
